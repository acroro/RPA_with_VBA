Function ResolveValue(val As String) As String
    Dim re As Object
    Dim matches As Object
    Dim m As Object
    Dim key As String
    Dim result As String
    Dim fso As Object
    Dim base As String
    Dim prop As String

    result = val
    Set re = CreateObject("VBScript.RegExp")
    re.Global = True
    re.Pattern = "\{([A-Za-z0-9_\.]+)\}"

    Set matches = re.Execute(val)
    Set fso = CreateObject("Scripting.FileSystemObject")

    For Each m In matches
        key = m.SubMatches(0)

        ' --- プロパティ付き {f.name} のような形式 ---
        If InStr(key, ".") > 0 Then
            base = Split(key, ".")(0)
            prop = Split(key, ".")(1)

            If gLoopVars.Exists(base) Then
                Dim full As String
                full = gLoopVars(base)

                Select Case LCase(prop)
                    Case "name"
                        result = Replace(result, "{" & key & "}", fso.GetFileName(full))
                    Case "basename"
                        result = Replace(result, "{" & key & "}", fso.GetBaseName(full))
                    Case "ext"
                        result = Replace(result, "{" & key & "}", fso.GetExtensionName(full))
                    Case "dir"
                        result = Replace(result, "{" & key & "}", fso.GetParentFolderName(full))
                    Case "path"
                        result = Replace(result, "{" & key & "}", full)
                End Select
            End If

        ' --- 通常の {f} / {var} ---
        Else
            ' ループ変数
            If gLoopVars.Exists(key) Then
                result = Replace(result, "{" & key & "}", gLoopVars(key))
            End If

            ' 通常変数
            If gVars.Exists(key) Then
                result = Replace(result, "{" & key & "}", gVars(key))
            End If
        End If
    Next

    ResolveValue = result
End Function
